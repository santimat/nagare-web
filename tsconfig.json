{
  "extends": "astro/tsconfigs/base",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "noCheck": true,
    "paths": {
      "@": ["./src/*"],
      "@icons": ["./src/icons/*"],
      "@components": ["./src/components/*"],
      "@assets": ["./src/assets/*"],
      "@styles": ["./src/styles/*"],
    },
  },
}
