---
import EnhancedIcon from "@icons/EnhancedPerson.svg";
import CloudIcon from "@icons/Cloud.svg";

const services = [
  "Landing Pages",
  "Diseño Web",
  "Logotipos",
  "Branding",
  "UX/UI",
  "Ecommerce",
];
---

<section id="services" class="services">
  <div>
    <h2>Servicios</h2>
    <p>
      Mezcla y combina nuestros servicios para que encajen con tus necesidades.
    </p>
  </div>
  <article class="services__heading-card">
    <div>
      <EnhancedIcon width={100} height={80} />
      <h3>¿Necesitás otra cosa?</h3>
    </div>
    <p>Contactanos para ver como podemos adaptarnos a tus necesidades.</p>
    <CloudIcon
      class={"services__heading-card-sticker"}
      width={90}
      height={80}
    />
  </article>
</section>
<style>
  .services {
    text-align: center;
    h2 {
      color: var(--color-accent);
      font-size: 2.3rem;
    }
    & > div p {
      color: var(--color-text);
      font-weight: 600;
    }
    .services__heading-card {
      background: var(--color-accent);
      border-radius: 2rem;
      color: var(--color-neutral);
      line-height: 1;
      margin: 2rem auto;
      padding: 1.4rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
      position: relative;
      width: clamp(280px, 90%, 320px);
      height: fit-content;
      & > div {
        align-items: center;
        display: flex;
        margin-bottom: 1.5rem;
        h3 {
          font-size: clamp(1.4rem, 8vw, 2.2rem);
          width: fit-content;
        }
      }
      p {
        font-size: clamp(1rem, 8vw, 1.6rem);
        text-align: left;
      }
    }
    .services__heading-card-sticker {
      bottom: -2rem;
      position: absolute;
      right: -0.5rem;
    }

    .services-list {
      color: var(--color-accent);
      font-weight: bolder;
      text-shadow: 2px 5px 5px rgba(0, 0, 0, 0.3);
    }
    .services-list p {
      font-size: clamp(2rem, 15vw, 4.7rem);
      line-height: 1;
    }
  }

  @media (width >= 768px) {
    .services {
    }
    .services div > h2 {
      font-size: 4.5rem;
      text-transform: uppercase;
      font-weight: bolder;
    }
    .services div > p {
      font-size: 1.5rem;
    }

    .services-list {
      position: relative;
      animation: scrollUp linear both;
      animation-timeline: view();
      animation-range: entry 20% cover 65%;
      p {
        margin-bottom: 1rem;
        margin-right: 1rem;
        text-align: end;
        animation: growIn ease both;
        animation-timeline: view();
        animation-range: entry 0% cover 40%;
        text-wrap: nowrap;
      }
    }

    @keyframes growIn {
      0% {
        transform: scale(0.7);
      }
      100% {
        transform: scale(1);
      }
    }
    @keyframes scrollUp {
      0% {
        transform: translateY(150px);
      }
      100% {
        transform: translateY(-100px);
      }
    }
  }
</style>
