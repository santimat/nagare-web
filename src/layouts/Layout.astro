---
import { ClientRouter } from "astro:transitions";
import Font from "astro/components/Font.astro";
import "@/global.css";
interface LayoutProps {
  title: string;
}

const { title = "" }: LayoutProps = Astro.props;

const titleToShow = title ? `- ${title}` : "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg" href="/favicon.svg" />
    <meta
      name="description"
      content="Nagare - Ofrecemos soluciones digitales para empresas y particulares"
    />
    <meta
      name="keywords"
      content="nagare, desarrollo web, diseño gráfico, marketing digital, soluciones digitales"
    />
    <meta name="author" content="Santino & Julieta" />
    <title>Nagare {titleToShow}</title>
    <ClientRouter />
    <Font cssVariable="--font-text" preload />
    <Font cssVariable="--font-heading" preload />
  </head>
  <body class="bg-neutral font-text animate-blurred-fade-in">
    <slot />
  </body>
</html>

<style>
  /* prevent that body can be scrolleable with the navbar deployed */
  body:has(#menu:checked) {
    overflow: hidden;
  }
</style>

<script>
  import AOS from "aos";
  import "aos/dist/aos.css";

  const init = () => {
    const config = {
      duration: 800,
    };

    AOS.init(config);
  };

  document.addEventListener("astro:page-load", init);
</script>
