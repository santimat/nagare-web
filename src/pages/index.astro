---
import Layout from "@/layouts/Layout.astro";

import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

import Hero from "@components/Home/Hero.astro";
import Description from "@components/Home/Description.astro";
import Clients from "@components/Home/Clients.astro";
import Services from "@components/Home/Services.astro";
import Packages from "@components/Home/Packages.astro";
import Faq from "@components/Home/Faq.astro";
---

<Layout title="Home">
  <Header />
  <main class="mt-10 mb-20 flex flex-col gap-40">
    <Hero />
    <Description />
    <Clients />
    <Services />
    <Packages />
    <Faq />
  </main>
  <Footer />
</Layout>

<style>
  .lazy-section {
    content-visibility: auto;
  }
</style>
