---
import HeaderIcon from "../icons/Header.astro";
import BurgerIcon from "../icons/Burguer.astro";

const navItems = [
  {
    href: "/#packages",
    text: "Precios",
  },
  {
    href: "/contact",
    text: "Contacto",
  },
  {
    href: "/#description",
    text: "Sobre nosotros",
  },
];
---

<header id="header" class="header">
  <div class="header__content">
    <div class="header__content-icon-container">
      <a href="/">
        <HeaderIcon />
      </a>
    </div>

    <label for="menu" class="header__content-menu-button">
      <BurgerIcon />
      <input type="checkbox" id="menu" />
    </label>
    <nav class="nav">
      <ul class="nav__ul">
        {
          navItems.map(({ href, text }) => (
            <li class="nav__ul-item">
              <a href={href}>{text}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  document.querySelectorAll(".nav a").forEach((link) => {
    link.addEventListener("click", () => {
      document.querySelector("#menu").checked = false;
    });
  });
</script>
<style>
  .header__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem;
    overflow: hidden;
    input[type="checkbox"] {
      display: none;
    }
  }

  .header__content-menu-button {
    user-select: none;
    transition:
      0.3s scale,
      rotate 0.3s;
    position: relative;
    z-index: 2;

    &:active {
      scale: 1.1;
    }
  }
  .header__content:has(input:checked) {
    .nav {
      animation: dance 0.5s forwards;
    }
    .header__content-menu-button {
      rotate: -45deg;
    }
  }

  .nav {
    display: grid;
    place-content: center;
    text-align: center;
    z-index: 1;
    position: absolute;
    inset: 0;
    transform: translateY(-1000px);
    min-height: 100dvh;
  }

  .nav__ul-item {
    color: var(--color-main);
    font-weight: bold;
    font-size: 1.5rem;
    transition: 0.3s scale;
    margin-bottom: 2rem;
    &:active {
      scale: 1.1;
    }
  }

  @media (width >= 768px) {
    .header__content-menu-button {
      display: none;
    }
    .nav {
      transform: translate(0);
      position: relative;
      min-height: auto;
    }
    .nav__ul {
      display: flex;
      gap: 2rem;
    }
    .nav__ul-item {
      &:hover {
        scale: 1.03;
        text-shadow: 1px 1px #0005;
      }
    }
  }

  @keyframes dance {
    0% {
      border-radius: 20%;
    }
    50% {
      border-radius: 0px 0px 70% 30% / 0px 0px 80% 40%;
    }
    100% {
      background: var(--color-neutral);
      transform: translateY(0px);
      border-radius: 0px;
    }
  }
</style>
