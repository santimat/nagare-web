---
import EnhancedIcon from "@icons/EnhancedPerson.astro";
import CloudIcon from "@icons/Cloud.astro";
---

<article
  class="bg-accent text-neutral relative mx-auto my-8 aspect-square max-h-64 max-w-96 rounded-4xl p-4 leading-none shadow-2xl"
>
  <div class="flex flex-col justify-around">
    <div class="mb-6 flex items-center">
      <EnhancedIcon class="h-auto w-24 md:w-36" />
      <h3 class="text-3xl text-balance md:text-4xl">¿Necesitás otra cosa?</h3>
    </div>
    <p class="text-left text-xl text-balance md:text-2xl">
      Contactanos para ver como podemos adaptarnos a tus necesidades.
    </p>
  </div>
  <CloudIcon class="absolute -right-2 -bottom-4 h-auto" width={90} />
</article>
