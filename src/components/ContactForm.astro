---
import { Image } from "astro:assets";
import CharacterImage from "@icons/Hero.astro";
---

<main class="relative h-full">
  <div class="text-neutral bg-main mx-auto mt-8 w-[90%] rounded-xl p-4 shadow-xl">
    <h1 class="font-heading mb-4 text-center text-3xl">Formulario de contacto</h1>
    <form>
      <div class="mb-4 flex flex-col">
        <label for="email" class="text-1xl font-text mb-1 ml-1">Coloque su email:</label>
        <div
          class="input-container bg-lighter focus:outline-neutral rounded-2xl opacity-80 transition duration-200 focus:outline-2 focus:outline-solid"
        >
          <input id="email" name="email" type="email" required />
        </div>
      </div>
      <div class="mb-16 flex flex-col">
        <label for="query" class="text-1xl font-text mb-1 ml-1">Coloque su consulta</label>
        <div
          class="input-container bg-lighter focus:outline-neutral rounded-2xl opacity-80 transition duration-200 focus:outline-2 focus:outline-solid"
        >
          <textarea class="resize-none overflow-y-auto" name="query" id="query" rows="6" cols="30"
          ></textarea>
        </div>
      </div>

      <p><button type="submit">Enviar consulta</button></p>
    </form>
    <div class="icon-container">
      <CharacterImage />
    </div>
  </div>
</main>

<style>
  form {
    input,
    textarea {
      width: 100%;
      font-size: 1.2rem;
      border-radius: 1rem;
      padding: 0.3rem;
      margin-left: 2px;
      background: transparent;
      border: none;
      opacity: 1;
      &:focus,
      &:focus-within {
        border: none;
        outline: none;
      }
    }
    p {
      display: flex;
      justify-content: end;
    }
    button {
      background: var(--color-accent);
      padding: 0.5rem 0.7rem;
      color: inherit;
      font-weight: bold;
      border-radius: 1rem;
      font-size: 1.4rem;
      transition: scale 0.3s;
      &:hover {
        scale: 1.011;
        cursor: pointer;
      }
    }
  }
  .icon-container {
    position: absolute;
    width: 25rem;
    bottom: 0;
    left: 0;
  }

  @media (width <= 768px) {
    .wrapper {
      width: 90%;
      margin-bottom: 2rem;
    }
    .icon-container {
      width: 9rem;
    }
  }
</style>
