---
import { Image } from "astro:assets";
import CharacterImage from "@icons/Hero.astro";
---

<main class="mb-20 h-full">
  <div
    class="text-neutral bg-main relative mx-auto mt-8 mb-8 w-[90%] rounded-xl p-4 shadow-xl md:max-w-2xl"
  >
    <h1 class="font-heading mb-4 text-center text-3xl">Formulario de contacto</h1>
    <form id="contact-form">
      <div class="mb-4 flex flex-col">
        <label for="email" class="text-1xl font-text mb-1 ml-1 font-bold">Coloque su email:</label>
        <div
          class="input-container bg-lighter focus:outline-neutral rounded-2xl opacity-80 transition duration-200 focus:outline-2 focus:outline-solid"
        >
          <input
            id="email"
            name="email"
            type="email"
            required
            class="ml-0.5 w-full rounded-2xl border-none bg-transparent p-2 text-xl opacity-100 focus-within:border-none focus-within:outline-none"
          />
        </div>
      </div>
      <div class="mb-16 flex flex-col">
        <label for="message" class="text-1xl font-text mb-1 ml-1 font-bold"
          >Coloque su consulta</label
        >
        <div
          class="input-container bg-lighter focus:outline-neutral rounded-2xl opacity-80 transition duration-200 focus:outline-2 focus:outline-solid"
        >
          <textarea
            class="ml-0.5 w-full resize-none overflow-y-auto rounded-2xl border-none bg-transparent p-2 text-xl text-inherit opacity-100 focus-within:border-none focus-within:outline-none"
            name="message"
            id="message"
            rows="6"
            cols="30"></textarea>
        </div>
      </div>

      <input
        class="bg-accent durationduration-300 ml-auto block rounded-xl p-2 text-2xl transition-transform hover:scale-105 hover:cursor-pointer"
        type="submit"
        value="Enviar consulta"
      />
    </form>
    <div>
      <CharacterImage
        class="absolute -bottom-4 -left-4 h-40 w-40 md:-bottom-15 md:-left-15 md:h-60 md:w-60"
      />
    </div>
  </div>
</main>

<script>
  const form = document.getElementById("contact-form");

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const toSend = {
      email: form.email.value,
      message: form.message.value,
    };

    const response = await sendEmail(toSend);
    console.log(response);

    // Opcional: Limpiar el formulario después de enviarlo
    // form.reset();
  });

  async function sendEmail({ email, message }) {
    const response = await fetch(`/api/emails/send-email`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ email, message }),
    });

    if (response.ok) {
      console.log("Email sent successfully");
    } else {
      console.error("Failed to send email");
    }
  }
</script>
