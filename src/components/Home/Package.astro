---
import Tag from "@icons/Tag.astro";
import PackageDetail from "@components/PackageDetail.astro";
import PackageButton from "./PackageButton.astro";

interface Detail {
  title: string;
  description: string;
}

interface PackageProps {
  title: string;
  description: string;
  details: Detail[];
  icon: boolean;
  price: number;
  kanji: string;
}

const { title, description, details, icon = false, price, kanji }: PackageProps = Astro.props;
---

<li class="flex">
  <article
    class="bg-lighter relative mx-auto flex h-full w-full flex-col rounded-4xl px-4 py-6 font-bold shadow-lg"
  >
    {icon && <Tag width={80} height={80} class="absolute -top-8 left-0" />}
    <span class="outlined-text text-accent text-outline absolute top-4 -right-2 rotate-20 text-5xl"
      >{kanji}</span
    >
    <h3 class="text-accent text-6xl capitalize md:text-7xl">{title}</h3>

    <ul class="text-text package-details my-10 text-2xl capitalize md:text-3xl">
      {
        details?.map(({ title, description }) => (
          <PackageDetail title={title} description={description} />
        ))
      }
    </ul>
    <span
      class="text-accent bg-neutral relative mx-auto block w-fit rounded-4xl px-5 py-3 text-4xl md:text-5xl"
      ><small class="outlined-text absolute -top-4 -left-4 -rotate-12 text-xl md:text-2xl"
        >Precio Total</small
      >${price}</span
    >
    <PackageButton text="Adquirir" class="mx-auto" />
  </article>
</li>

<script>
  // accordion for package details
  document.querySelectorAll(".package-details li").forEach((detail) => {
    detail.addEventListener("click", (e) => {
      // get element which has listener associated to it
      const targetedDetail = e.currentTarget;
      const detailDescription = targetedDetail.querySelector("div");
      const detailChevron = targetedDetail.querySelector("h4 svg");
      const isOpen = detailDescription.style.maxHeight !== "";

      detailChevron.classList.toggle("rotate-90");
      if (!isOpen) {
        detailDescription.style.maxHeight = `${detailDescription.scrollHeight}px`;
        return;
      }

      detailDescription.style.maxHeight = null;
    });
  });
</script>
